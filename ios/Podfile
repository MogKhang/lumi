# Uncomment this line to define a global platform for your project
platform :ios, '15.5'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

# Disable file_picker's media picker on iOS - removes DKImagePickerController dependency
# This app only uses file_picker for directory selection on desktop
Pod.const_set(:PICKER_MEDIA, false) unless Pod.const_defined?(:PICKER_MEDIA)

flutter_ios_podfile_setup

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # Flutter regenerates FlutterGeneratedPluginSwiftPackage/Package.swift with a
  # hardcoded `.iOS("13.0")` default and only bumps it to the real deployment
  # target during a full `flutter build ios` — building directly in Xcode never
  # triggers that bump, so plugins requiring iOS 14+ (background_downloader) fail
  # with "requires minimum platform version 14.0 ... but this target supports 13.0".
  # Patch it here so it stays correct after every pod install, however it was regenerated.
  generated_package = File.expand_path(
    File.join('Flutter', 'ephemeral', 'Packages', 'FlutterGeneratedPluginSwiftPackage', 'Package.swift'),
    __dir__,
  )
  if File.exist?(generated_package)
    contents = File.read(generated_package)
    patched = contents.sub(/\.iOS\("13\.0"\)/, '.iOS("15.5")')
    if patched != contents
      File.write(generated_package, patched)
      Pod::UI.puts "[lumi] Patched FlutterGeneratedPluginSwiftPackage iOS platform 13.0 -> 15.5"
    end
  end

  # file_picker's SPM manifest unconditionally compiles in the iOS media picker
  # (PICKER_MEDIA) and pulls in DKImagePickerController, which references the photo
  # library (PHPhotoLibrary) and location (CLLocation) APIs. Lumi only uses
  # file_picker for directory selection, never the media picker — but Apple's
  # static binary scan still rejects the upload for missing NSPhotoLibraryUsageDescription
  # / NSLocationWhenInUseUsageDescription. The CocoaPods `Pod::PICKER_MEDIA = false`
  # above is ignored under SPM, so strip the media picker from the SPM manifest here.
  # The manifest lives in the pub cache and is regenerated by `flutter pub get`,
  # so this re-applies (idempotently) on every pod install.
  file_picker_manifest = File.join(
    __dir__, 'Flutter', 'ephemeral', 'Packages', '.packages', 'file_picker-10.3.10', 'Package.swift',
  )
  if File.exist?(file_picker_manifest)
    contents = File.read(file_picker_manifest)
    patched = contents
      .sub(/^\s*\.package\(url: "https:\/\/github\.com\/zhangao0086\/DKImagePickerController".*\n/, "")
      .sub(/^\s*\.product\(name: "DKImagePickerController", package: "DKImagePickerController"\)\n/, "")
      .sub(/^\s*\.define\("PICKER_MEDIA"\),\n/, "")
      .sub(/^\s*\.define\("PICKER_AUDIO"\),\n/, "")
      # Leaving the dependencies array with no entries is fine; drop a now-dangling
      # trailing comma inside the (now empty) target dependencies list if present.
      .sub(/dependencies: \[\s*\],/m, "dependencies: [],")
    if patched != contents
      File.write(file_picker_manifest, patched)
      Pod::UI.puts "[lumi] Stripped DKImagePickerController / PICKER_MEDIA from file_picker SPM manifest"
    end
  end
end
